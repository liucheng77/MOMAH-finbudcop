  title: { en: "Full flow — Revenue Collection × Assets (G-06)", ar: "المسار الكامل — التحصيل × الأصول (ج-06)", zh: "完整流程 — 收入征收 × 资产(G-06)" },
  nodes: PLAZA_UCS, intra: PLAZA_INTRA, cross: PLAZA_CROSS,
};

